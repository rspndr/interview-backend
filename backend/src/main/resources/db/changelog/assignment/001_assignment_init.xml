<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">
    <changeSet id="assignment-001" author="gavynholt">
        <createTable tableName="assignment">
            <column name="id" type="uuid" defaultValue="gen_random_uuid()">
                <constraints primaryKey="true" primaryKeyName="assignment_id_pk" />
            </column>
            <column name="created_at" type="timestamp with time zone" />
            <column name="name" type="text" />
            <column name="company_code" type="text" />
            <column name="location" type="FLOAT8[]"/>
            <column name="deleted" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false" />
            </column>
        </createTable>
    </changeSet>
</databaseChangeLog>