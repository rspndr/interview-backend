<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">
    <changeSet id="user-001" author="gavynholt">
        <createTable tableName="user">
            <column name="id" type="uuid" defaultValue="gen_random_uuid()">
                <constraints primaryKey="true" primaryKeyName="user_id_pk" />
            </column>
            <column name="created_at" type="timestamp with time zone" />
            <column name="username" type="text" />
            <column name="first_name" type="text" />
            <column name="last_name" type="text" />
            <column name="email" type="text" />
            <column name="company_code" type="text" />
            <column name="location" type="FLOAT8[]"/>
        </createTable>
    </changeSet>
</databaseChangeLog>